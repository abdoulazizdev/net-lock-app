{
  "expo": {
    "name": "NetOff",
    "slug": "netoff",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/netoff_icon.png",
    "scheme": "netoff",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.netoff.app",
      "icon": "./assets/icons/netoff_icon.png"
    },
    "android": {
      "package": "com.netoff.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "INTERNET",
        "BIND_VPN_SERVICE",
        "QUERY_ALL_PACKAGES",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/netoff_foreground.png",
        "backgroundImage": "./assets/icons/netoff_background.png"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icons/netoff_icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/netoff_icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "31d284c3-e169-4330-ae67-367c2a8eed64"
      }
    }
  }
}
