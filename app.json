{
  "expo": {
    "name": "NetOff",
    "slug": "netoff",
    "version": "1.0.7",
    "orientation": "portrait",
    "icon": "./assets/icons/netoff_icon.png",
    "scheme": "netoff",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.netoff.app",
      "icon": "./assets/icons/netoff_icon.png",
      "buildNumber": "7",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Utilisé pour sécuriser l'accès à l'application."
      }
    },

    "android": {
      "package": "com.netoff.app",
      "versionCode": 7,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,

      "permissions": [
        "INTERNET",
        "BIND_VPN_SERVICE",
        "QUERY_ALL_PACKAGES",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "FOREGROUND_SERVICE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "SYSTEM_ALERT_WINDOW",
        "VIBRATE",
        "WAKE_LOCK"
      ],

      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/netoff_foreground.png",
        "backgroundImage": "./assets/icons/netoff_background.png"
      },

      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "netoff"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },

    "web": {
      "output": "static",
      "favicon": "./assets/icons/netoff_icon.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/netoff_icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "31d284c3-e169-4330-ae67-367c2a8eed64"
      }
    },

    "updates": {
      "fallbackToCacheTimeout": 0
    },

    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
